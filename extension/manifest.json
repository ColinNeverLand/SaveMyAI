{
  "manifest_version": 3,
  "name": "SaveMyAI",
  "version": "0.2.0",
  "description": "导出豆包智能体的人设与完整聊天记录，并一键转换为 SillyTavern 可导入的角色卡与聊天记录。所有数据仅保存在本地，不上传任何服务器。",
  "permissions": ["storage"],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*", "https://doubao.com/*"],
      "js": ["convert.js", "worldinfo.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SaveMyAI 设置"
  }
}
